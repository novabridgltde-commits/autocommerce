# AutoCommerce V25 — Variables frontend
# Copiez en .env.local pour développement local
# En production: VITE_API_URL doit pointer vers votre domaine API

# URL de l'API backend (sans slash final)
# En développement: http://localhost:8000/api/v1
# En production:    https://api.votredomaine.com/api/v1
# Laisser vide = utilise le même domaine que le frontend (proxy Nginx recommandé)
VITE_API_URL=http://localhost:8000/api/v1

# ── RGPD / Politique de confidentialité ─────────────────────────────────────
# Ces variables personnalisent la page /privacy sans modifier le code.
# Laissez vide pour utiliser les valeurs par défaut AutoCommerce.
VITE_COMPANY_NAME=AutoCommerce SaaS
VITE_COMPANY_ADDRESS=Tunisie
VITE_PRIVACY_EMAIL=privacy@autocommerce.io

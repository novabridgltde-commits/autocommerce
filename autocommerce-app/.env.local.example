# Copy this to .env.local and fill in your values.
# NEVER commit .env.local — it is in .gitignore.

# API base URL for local development
VITE_API_URL=http://localhost:8000/api/v1

# For production, leave VITE_API_URL empty (same-origin via Nginx)
# VITE_API_URL=

# RGPD branding (optional)
# VITE_COMPANY_NAME=Ma Société SARL
# VITE_COMPANY_ADDRESS=12 Rue du Commerce, 75001 Paris
# VITE_PRIVACY_EMAIL=dpo@masociete.fr

# ─── OmniCall V9 Feature Flags ────────────────────────────────────────────────
# BLOC 7 — Shadow Mode (observation sans impact sur V8)
# Activer pour observer V9 en parallèle de V8 (aucun impact prod)
OMNICALL_V9_SHADOW_MODE=0

# BLOC 9 — Rollout partiel (activer V9 progressivement)
# Activer V9 en mode actif (après validation du shadow mode)
OMNICALL_V9_ENABLED=0

# Pourcentage de trafic routé vers V9 (0-100, défaut 0)
# Exemple : 5 = 5% du trafic vers V9
OMNICALL_V9_ROLLOUT_PCT=0

# Liste des store_id beta (toujours routés vers V9, séparés par virgule)
# Exemple : "1,2,3" = stores 1, 2 et 3 sont en beta
OMNICALL_V9_BETA_STORES=

# Lecture duale (futur - comparaison V8/V9)
OMNICALL_V9_DUAL_READ=0

# ─── Social Webhooks (BLOC 7 - nouveaux endpoints) ───────────────────────────
# Token de vérification pour Instagram (Meta Graph API)
INSTAGRAM_VERIFY_TOKEN=your_instagram_verify_token
INSTAGRAM_APP_SECRET=your_instagram_app_secret

# Token de vérification pour Facebook Messenger
FACEBOOK_VERIFY_TOKEN=your_facebook_verify_token
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ─── Procédure de rollout progressif ─────────────────────────────────────────
# ÉTAPE 1 : Shadow Mode (1-3 jours minimum)
#   OMNICALL_V9_SHADOW_MODE=1
#   → Observer les logs omnicall_v9.shadow.* et GET /api/v1/omnicall-v9/report
#   → Vérifier que le taux d'acceptation est > 95%
#
# ÉTAPE 2 : Beta users (stores sélectionnés)
#   OMNICALL_V9_ENABLED=1
#   OMNICALL_V9_BETA_STORES=1,2,3
#   OMNICALL_V9_ROLLOUT_PCT=0
#   → Les stores beta passent en actif V9, le reste reste en fallback/shadow
#
# ÉTAPE 3 : Rollout 5-10%
#   OMNICALL_V9_ENABLED=1
#   OMNICALL_V9_ROLLOUT_PCT=5
#   → Observer pendant 24-48h
#   → Puis passer à 10% si les logs restent propres
#   → Si OK, augmenter ensuite à 25%, 50%, 100%
#
# ÉTAPE 4 : Full rollout
#   OMNICALL_V9_ROLLOUT_PCT=100

# CSRF Protection — REQUIRED in multi-worker deployments
# Generate with: openssl rand -hex 32
CSRF_SECRET=CHANGE_ME_openssl_rand_hex_32

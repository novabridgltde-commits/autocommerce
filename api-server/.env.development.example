ENV=development
DEBUG=true
PORT=8000
UVICORN_WORKERS=1
# HIGH-14 FIX: PostgreSQL requis même en développement.
# Lancer: docker-compose -f docker-compose.dev.yml up -d
DATABASE_URL=postgresql+asyncpg://autocommerce:autocommerce@localhost:5432/autocommerce_dev
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=dev-secret-key-change-me-32-chars-min
ENCRYPTION_KEY=REPLACE_WITH_VALID_FERNET_KEY
OPENAI_API_KEY=sk-dev-placeholder
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
OPENAI_LOW_COST_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
FEATURE_FLAG_DEEPSEEK=true
FEATURE_FLAG_OPENAI_FALLBACK=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
SERVER_DOMAIN=http://localhost:8000
SENTRY_DSN=
INTERNAL_HEALTH_TOKEN=dev_health_token_change_me
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=dev_whatsapp_verify_token
WHATSAPP_PHONE_NUMBER_ID=
INSTAGRAM_VERIFY_TOKEN=dev_instagram_verify_token
INSTAGRAM_APP_SECRET=
FACEBOOK_VERIFY_TOKEN=dev_facebook_verify_token
FACEBOOK_APP_SECRET=
TIKTOK_APP_SECRET=
TIKTOK_VERIFY_TOKEN=dev_tiktok_verify_token
TIKTOK_ENABLED=false
TIKTOK_ALLOW_REAL_CALLS=false
OMNICALL_V9_SHADOW_MODE=0
OMNICALL_V9_ENABLED=0
OMNICALL_V9_ROLLOUT_PCT=0
OMNICALL_V9_BETA_STORES=
AI_BUDGET_HARD_LIMIT_USD=250
AI_MAX_MONTHLY_CALLS=10000
AI_MAX_MONTHLY_TOKENS=2000000
AI_WARNING_THRESHOLD_PCT=80
AI_DEGRADED_THRESHOLD_PCT=100
AI_CONTROLLED_FALLBACK_MESSAGE=Service IA momentanément limité pour ce tenant. Merci de réessayer plus tard.
SAAS_BILLING_WEBHOOK_SECRET=

# CSRF Protection (auto-generated in dev if absent, but set for consistency)
CSRF_SECRET=dev-csrf-secret-change-in-production

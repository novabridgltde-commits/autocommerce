# ──────────────────────────────────────────────────────────────────────────────
# AutoCommerce — Template d'environnement
# Copiez ce fichier en `.env` puis remplacez chaque CHANGE_ME_* par une vraie valeur.
# Générer les secrets : bash scripts/generate_secrets.sh
# ──────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
ENV=development
DEBUG=False
SERVER_DOMAIN=https://api.yourdomain.tn
CORS_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://autocommerce:CHANGE_ME_$(openssl rand -hex 8)@localhost/autocommerce

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_RATELIMIT_URL=
REDIS_CACHE_URL=
REDIS_PASSWORD=
REDIS_SENTINEL_MASTER=mymaster
REDIS_SENTINEL_PASSWORD=
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5.0
REDIS_SOCKET_CONNECT_TIMEOUT=3.0

# ── Secrets — DOIVENT être régénérés via scripts/generate_secrets.sh ─────────
JWT_SECRET_KEY=CHANGE_ME_$(openssl rand -hex 32)
ENCRYPTION_KEY=CHANGE_ME_$(python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEYS_JSON=
CSRF_SECRET=CHANGE_ME_$(openssl rand -hex 32)
INTERNAL_HEALTH_TOKEN=CHANGE_ME_$(openssl rand -hex 32)

# ── Passwords initiaux ───────────────────────────────────────────────────────
ADMIN_INITIAL_PASSWORD=CHANGE_ME_$(openssl rand -hex 8)
SUPERADMIN_INITIAL_PASSWORD=CHANGE_ME_$(openssl rand -hex 8)

# ── WhatsApp ─────────────────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=CHANGE_ME_$(openssl rand -hex 16)
WHATSAPP_VERIFY_TOKEN=CHANGE_ME_$(openssl rand -hex 24)
WHATSAPP_PHONE_NUMBER_ID=

# ── Instagram ────────────────────────────────────────────────────────────────
INSTAGRAM_VERIFY_TOKEN=CHANGE_ME_$(openssl rand -hex 24)
INSTAGRAM_APP_SECRET=CHANGE_ME_$(openssl rand -hex 16)

# ── Facebook ─────────────────────────────────────────────────────────────────
FACEBOOK_VERIFY_TOKEN=CHANGE_ME_$(openssl rand -hex 24)
FACEBOOK_APP_SECRET=CHANGE_ME_$(openssl rand -hex 16)

# ── TikTok ───────────────────────────────────────────────────────────────────
TIKTOK_APP_SECRET=
TIKTOK_VERIFY_TOKEN=CHANGE_ME_$(openssl rand -hex 24)
TIKTOK_ENABLED=False
TIKTOK_ALLOW_REAL_CALLS=False

# ── Alertes ──────────────────────────────────────────────────────────────────
SLACK_ALERT_WEBHOOK=
EMOTION_ESCALATION_THRESHOLD=2

# ── OmniCall V9 Feature Flags ────────────────────────────────────────────────
OMNICALL_V9_SHADOW_MODE=0
OMNICALL_V9_ENABLED=0
OMNICALL_V9_ROLLOUT_PCT=0
OMNICALL_V9_BETA_STORES=

# ── Providers IA ─────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
FEATURE_FLAG_DEEPSEEK=True
FEATURE_FLAG_OPENAI_FALLBACK=True
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o
OPENAI_LOW_COST_MODEL=gpt-4o-mini

# ── SaaS / FinOps ────────────────────────────────────────────────────────────
AI_BUDGET_HARD_LIMIT_USD=250.0
AI_MAX_MONTHLY_CALLS=10000
AI_MAX_MONTHLY_TOKENS=2000000
AI_WARNING_THRESHOLD_PCT=80
AI_DEGRADED_THRESHOLD_PCT=100
AI_CONTROLLED_FALLBACK_MESSAGE=Service IA momentanément limité pour ce tenant. Merci de réessayer plus tard.
SAAS_BILLING_WEBHOOK_SECRET=

# ── Sécurité inputs IA ───────────────────────────────────────────────────────
MAX_INPUT_LENGTH=2000
RESET_TOKEN_TTL=900

# ── Runtime tuning ───────────────────────────────────────────────────────────
PORT=8000
UVICORN_WORKERS=8
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=3
DB_STATEMENT_TIMEOUT_MS=30000

# ── Sentry (optionnel) ───────────────────────────────────────────────────────
SENTRY_DSN=

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_SOFT_TIME_LIMIT=120
CELERY_TIME_LIMIT=300
CELERY_MAX_TASKS_PER_CHILD=200
CELERY_MAX_MEMORY_KB=400000
CELERY_BROKER_POOL_LIMIT=10

# ── Rate limits ──────────────────────────────────────────────────────────────
RL_LOGIN_LIMIT=10
RL_LOGIN_WINDOW=60
RL_REGISTER_LIMIT=5
RL_REGISTER_WINDOW=60
RL_FORGOT_LIMIT=5
RL_FORGOT_WINDOW=3600
RL_AI_LIMIT=60
RL_AI_WINDOW=60
RL_UPLOAD_LIMIT=30
RL_UPLOAD_WINDOW=60
RL_WEBHOOK_LIMIT=600
RL_WEBHOOK_WINDOW=60

# ── Circuit breakers ─────────────────────────────────────────────────────────
CB_OPENAI_THRESHOLD=6
CB_OPENAI_COOLDOWN=45
CB_STRIPE_THRESHOLD=5
CB_STRIPE_COOLDOWN=30

# ── Uploads ──────────────────────────────────────────────────────────────────
UPLOAD_MAX_BYTES_IMAGE=5242880
UPLOAD_MAX_BYTES_DOCUMENT=10485760
UPLOAD_STORAGE_ROOT=uploads

# ── S3 / MinIO ───────────────────────────────────────────────────────────────
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=autocommerce-uploads
S3_REGION=us-east-1
S3_USE_PRESIGNED_URLS=True
S3_PRESIGNED_EXPIRY=3600
S3_PUBLIC_URL=

# ── PostgreSQL HA ────────────────────────────────────────────────────────────
POSTGRES_REPLICATION_PASSWORD=

# ── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
METRICS_ENABLED=True
OTLP_ENDPOINT=
OTLP_INSECURE=False
PROMETHEUS_INTERNAL_TOKEN=
ALERTMANAGER_TARGET=alertmanager:9093

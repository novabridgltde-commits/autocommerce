# SaaS overlay
AI_BUDGET_HARD_LIMIT_USD=250
AI_MAX_MONTHLY_CALLS=10000
AI_MAX_MONTHLY_TOKENS=2000000
AI_WARNING_THRESHOLD_PCT=80
AI_DEGRADED_THRESHOLD_PCT=100
AI_CONTROLLED_FALLBACK_MESSAGE=Service IA momentanement limite pour ce tenant. Merci de reessayer plus tard.
OPENAI_LOW_COST_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
FEATURE_FLAG_DEEPSEEK=true
FEATURE_FLAG_OPENAI_FALLBACK=true
SAAS_BILLING_WEBHOOK_SECRET=change-me

# Existing settings
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/autocommerce
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change-me
ENCRYPTION_KEY=replace-with-valid-fernet-key
OPENAI_API_KEY=replace-me
CORS_ORIGINS=https://app.example.com
WHATSAPP_VERIFY_TOKEN=change-me
INSTAGRAM_VERIFY_TOKEN=change-me
FACEBOOK_VERIFY_TOKEN=change-me
TIKTOK_VERIFY_TOKEN=change-me

# CSRF Protection — REQUIRED in multi-worker deployments
# Generate with: openssl rand -hex 32
CSRF_SECRET=CHANGE_ME_openssl_rand_hex_32
POSTGRES_PASSWORD=CHANGE_ME_$(openssl rand -hex 16)

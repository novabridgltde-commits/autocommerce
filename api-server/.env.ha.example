# ═══════════════════════════════════════════════════════════════════════════════
# .env.ha.example — AutoCommerce V11 — Production HA Environment Variables
# Copier vers .env.production et remplir les valeurs réelles.
# JAMAIS committer .env.production dans le dépôt git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
ENV=production
DEBUG=false
SECRET_KEY=CHANGE_ME_min_32_chars_openssl_rand_hex_32
JWT_SECRET_KEY=CHANGE_ME_min_32_chars_openssl_rand_hex_32
INTERNAL_HEALTH_TOKEN=CHANGE_ME_strong_token

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@pgbouncer:6432/autocommerce
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_REPLICATION_PASSWORD=CHANGE_ME

# ── Redis HA ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis-master:6379/0
REDIS_PASSWORD=CHANGE_ME
REDIS_SENTINEL_MASTER=mymaster
REDIS_SENTINEL_PASSWORD=CHANGE_ME

# ── S3 / MinIO (BLOCANT #4 FIX) ──────────────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME_strong_password
S3_BUCKET=autocommerce-uploads
S3_REGION=us-east-1
S3_USE_PRESIGNED_URLS=true
S3_PRESIGNED_EXPIRY=3600
S3_PUBLIC_URL=                        # optionnel : CDN URL devant MinIO

MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME_strong

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=CHANGE_ME

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
FEATURE_FLAG_DEEPSEEK=true
FEATURE_FLAG_OPENAI_FALLBACK=true

# ── WhatsApp / Meta ───────────────────────────────────────────────────────────
WHATSAPP_APP_SECRET=CHANGE_ME
WHATSAPP_VERIFY_TOKEN=CHANGE_ME_strong_random_token
INSTAGRAM_VERIFY_TOKEN=CHANGE_ME_strong_random_token
FACEBOOK_VERIFY_TOKEN=CHANGE_ME_strong_random_token
META_APP_SECRET=CHANGE_ME

# ── TikTok ───────────────────────────────────────────────────────────────────
TIKTOK_APP_SECRET=CHANGE_ME

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=CHANGE_ME
STRIPE_WEBHOOK_SECRET=CHANGE_ME

# ── Nginx ────────────────────────────────────────────────────────────────────
SERVER_NAME=api.yourdomain.com

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:CHANGE_ME@redis-master:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@redis-master:6379/2

# ── Flower Monitoring ─────────────────────────────────────────────────────────
FLOWER_BASIC_AUTH_USER=admin
FLOWER_BASIC_AUTH_PASSWORD=CHANGE_ME_strong

# ── SAAS ─────────────────────────────────────────────────────────────────────
SAAS_BILLING_WEBHOOK_SECRET=CHANGE_ME
FERNET_SECRET_KEY=CHANGE_ME_fernet_key_base64_32_bytes

# ── DLQ Management ───────────────────────────────────────────────────────────
DLQ_MAX_LEN=10000
DLQ_WARN_LEN=1000

# CSRF Protection — REQUIRED in multi-worker deployments
# Generate with: openssl rand -hex 32
CSRF_SECRET=CHANGE_ME_openssl_rand_hex_32

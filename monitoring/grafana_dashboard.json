    {
      "id": 12,
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "type": "table",
      "title": "Opérations Redis par type",
      "targets": [
        {
          "expr": "rate(redis_operations_total[5m])",
          "legendFormat": "{{operation}} / {{outcome}}",
          "instant": true
        }
      ],
      "options": {
        "showHeader": true
      }
    }
  ]
}
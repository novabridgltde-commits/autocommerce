        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "type": "timeseries",
      "title": "LLM Tokens consommés / 5m",
      "targets": [
        {
          "expr": "rate(llm_tokens_total{token_type=\"prompt\"}[5m])",
          "legendFormat": "prompt {{model}}"

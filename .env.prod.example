# =============================================================================
# AutoCommerce V25 — .env.prod.example
# Copiez en .env.prod et remplissez TOUS les CHANGE_ME_ avant de déployer.
#
# Générer les secrets : bash scripts/generate_secrets.sh
# Vérifier avant déploiement : bash scripts/test_deployment.sh
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
ENV=production
DEBUG=False
LOG_LEVEL=INFO
LOG_FORMAT=json
SERVER_DOMAIN=https://votre-domaine.com
CORS_ORIGINS=https://votre-domaine.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=autocommerce
POSTGRES_PASSWORD=CHANGE_ME_min16chars
POSTGRES_DB=autocommerce
DATABASE_URL=postgresql+asyncpg://autocommerce:CHANGE_ME_min16chars@postgres:5432/autocommerce

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_min16chars
REDIS_URL=redis://:CHANGE_ME_min16chars@redis:6379/0
REDIS_RATELIMIT_URL=redis://:CHANGE_ME_min16chars@redis:6379/1
REDIS_CACHE_URL=redis://:CHANGE_ME_min16chars@redis:6379/2
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5.0
REDIS_SOCKET_CONNECT_TIMEOUT=3.0

# ── Secrets JWT / Chiffrement ─────────────────────────────────────────────────
# Générer : openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_64hex_chars_minimum
# Générer : python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_fernet_key
FERNET_KEYS_JSON=
# Générer : openssl rand -hex 32
CSRF_SECRET=CHANGE_ME_64hex_chars_minimum

# ── Tokens internes ────────────────────────────────────────────────────────────
# Générer : openssl rand -hex 32
INTERNAL_HEALTH_TOKEN=CHANGE_ME_64hex_chars
PROMETHEUS_INTERNAL_TOKEN=CHANGE_ME_64hex_chars

# ── Seed admin (utilisé UNE SEULE FOIS au premier démarrage) ──────────────────
ADMIN_INITIAL_PASSWORD=CHANGE_ME_strong_password_12chars
SUPERADMIN_INITIAL_PASSWORD=CHANGE_ME_strong_password_12chars

# ── Uvicorn ───────────────────────────────────────────────────────────────────
UVICORN_WORKERS=4
PORT=8000

# ── WhatsApp (BYOK — optionnel au déploiement initial) ────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Réseaux sociaux (BYOK par tenant — optionnel) ─────────────────────────────
INSTAGRAM_VERIFY_TOKEN=
INSTAGRAM_APP_SECRET=
FACEBOOK_VERIFY_TOKEN=
FACEBOOK_APP_SECRET=
TIKTOK_APP_SECRET=
TIKTOK_VERIFY_TOKEN=
TIKTOK_ENABLED=False
TIKTOK_ALLOW_REAL_CALLS=False

# ── IA / LLM (BYOK par tenant — optionnel) ────────────────────────────────────
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ── Stripe (optionnel si module billing activé) ────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── S3 / Stockage objets (optionnel — sinon stockage local) ───────────────────
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=autocommerce-uploads
S3_REGION=us-east-1
S3_USE_PRESIGNED_URLS=True
S3_PRESIGNED_EXPIRY=3600
S3_PUBLIC_URL=

# ── Monitoring / Alerting (optionnel) ─────────────────────────────────────────
METRICS_ENABLED=True
OTLP_ENDPOINT=
SLACK_ALERT_WEBHOOK=
ALERTMANAGER_TARGET=alertmanager:9093

# ── OmniCall V9 (désactivé par défaut) ────────────────────────────────────────
OMNICALL_V9_ENABLED=0
OMNICALL_V9_SHADOW_MODE=0
OMNICALL_V9_ROLLOUT_PCT=0
OMNICALL_V9_BETA_STORES=

# ── Rate limiting (valeurs production recommandées) ────────────────────────────
RL_LOGIN_LIMIT=5
RL_LOGIN_WINDOW=300
RL_REGISTER_LIMIT=3
RL_REGISTER_WINDOW=3600
RL_FORGOT_LIMIT=3
RL_FORGOT_WINDOW=3600
RL_AI_LIMIT=60
RL_AI_WINDOW=60
RL_UPLOAD_LIMIT=30
RL_UPLOAD_WINDOW=60
RL_WEBHOOK_LIMIT=600
RL_WEBHOOK_WINDOW=60

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOAD_MAX_BYTES_IMAGE=5242880
UPLOAD_MAX_BYTES_DOCUMENT=10485760
UPLOAD_STORAGE_ROOT=uploads
